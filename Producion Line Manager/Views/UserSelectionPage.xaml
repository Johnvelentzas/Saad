<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Models.Production;assembly=Models"
             xmlns:vm="clr-namespace:Producion_Line_Manager.ViewModels"
             x:Class="Producion_Line_Manager.Views.UserSelectionPage"
             x:DataType="vm:UserSelectionViewModel"
             Title="{Binding Title}"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
             NavigationPage.HasNavigationBar="False"
             Padding="50, 30, 50, 0">
    <CollectionView ItemsSource="{Binding Users}">
        <CollectionView.ItemsLayout>
            <GridItemsLayout Orientation="Vertical"
                             Span="5"
                             HorizontalItemSpacing="20"
                             VerticalItemSpacing="50"/>
        </CollectionView.ItemsLayout>
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="models:Users">
                <VerticalStackLayout Spacing="5">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:UserSelectionViewModel}}, Path=SelectUserCommand}"
                                              CommandParameter="{Binding .}"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Border HeightRequest="150" 
                            WidthRequest="150" 
                            HorizontalOptions="Center" 
                            VerticalOptions="Center"
                            Background="LightGrey" 
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="30" />
                        </Border.StrokeShape>
                    </Border>
                    <Label Text="{Binding Name}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           FontSize="16"/>

                </VerticalStackLayout>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>