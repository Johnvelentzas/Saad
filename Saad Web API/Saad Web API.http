@root = http://localhost:5167

### Returns a list of all processes in the database
GET {{root}}/api/Processes/
Accept: application/json

### Returns a list of all Users in the database
GET {{root}}/api/Users/
Accept: application/json

### Returns a list of all UserProcesses in the database
GET {{root}}/api/UserProcesses/
Accept: application/json

### Returns a list of all UserProcesses of admin user with id 1
GET {{root}}/api/Users/1/Processes
Accept: application/json

### Returns a list of all UserProcesses of user with id 1
GET {{root}}/api/Users/2/Processes
Accept: application/json

### Returns a list of all customers in the database.
GET {{root}}/api/Customers/
Accept: application/json

### Returns a single customer with the specified ID.
GET {{root}}/api/Customers/1
Accept: application/json

### Updates a customer on the database
PUT {{root}}/api/Customers/1
Content-Type: application/json

{
  "Id": "1",
  "FirstName": "Yiannis", 
  "LastName": "Velentzas", 
  "Email": "yiannis.velentzas@gmail.com", 
  "Telephone": "+30 6994443633", 
  "TaxNumber": "123456789",
  "CreatedDate": "2026-03-06"
}

###
POST {{root}}/api/Customers
Content-Type: application/json

{
  "FirstName": "John", 
  "LastName": "Velentzas", 
  "Email": "yiannis.velentzas@gmail.com", 
  "Telephone": "+30 6994443633", 
  "TaxNumber": "123456789",
  "CreatedDate": "2026-03-06"
}

###
GET {{root}}/api/Customers/1
Accept: application/json